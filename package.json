{
  "name": "mlb-edge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "cd client && pnpm dev",
    "dev:server": "cd server && pnpm dev",
    "build": "cd client && pnpm build",
    "db:push": "cd server && pnpm db:push",
    "db:studio": "cd server && pnpm db:studio",
    "db:generate": "cd server && pnpm db:generate"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
